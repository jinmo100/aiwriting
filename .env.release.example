# Copy this file to `.env` before running docker-compose.release.yml.
# Never commit the filled `.env` file.

# Image version:
# - latest: latest stable release from a v* git tag
# - edge: latest main branch build
# - v2.3.0: fixed release
# - main-<shortSha>: exact main commit build
APP_VERSION=latest

# Bundled PostgreSQL defaults. Change all passwords before exposing a real service.
POSTGRES_DB=essay_evaluator
POSTGRES_USER=essay_evaluator
POSTGRES_PASSWORD=change-me-to-a-long-random-password

# Required by backend AES-GCM encryption of user API keys.
ESSAY_EVALUATOR_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars

# Keep registration open for first startup. Set to false after creating your account if needed.
ESSAY_EVALUATOR_REGISTRATION_ENABLED=true

# HTTP/IP access: false. HTTPS reverse proxy: set true.
ESSAY_EVALUATOR_SESSION_COOKIE_SECURE=false

# Frontend publishes only one HTTP port. Bind to 127.0.0.1 when a host reverse proxy is in front.
FRONTEND_BIND=0.0.0.0
FRONTEND_PORT=8088

# Optional overrides for advanced users.
# BACKEND_IMAGE=ghcr.io/jinmo100/essay-evaluator-backend
# FRONTEND_IMAGE=ghcr.io/jinmo100/essay-evaluator-frontend
# DB_HOST=postgres
# DB_PORT=5432
# REDIS_URL=redis://redis:6379/0
# JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -Dfile.encoding=UTF-8
