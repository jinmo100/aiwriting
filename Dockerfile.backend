FROM openjdk:21-jdk-slim

WORKDIR /app

# 安装必要的工具
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 复制jar包
COPY build/libs/aiwriting.jar app.jar

# 暴露端口
EXPOSE 8080

# JVM参数
ENV JAVA_OPTS="-XX:+UseZGC -XX:+ZGenerational -Xmx2g -XX:+UseCompressedOops -XX:+UseCompressedClassPointers -Dfile.encoding=UTF-8"

# 启动应用
ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar app.jar"]
