# Copy to .env for Docker Compose or production-like local deployment.
# .env is ignored by git. Replace all change-me values before use.

POSTGRES_DB=essay_evaluator
POSTGRES_USER=essay_evaluator
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

BACKEND_PORT=8080
FRONTEND_PORT=80

ESSAY_EVALUATOR_SECRET_KEY=change-me-at-least-32-chars
