# Copy to .env.dev.local and adjust for your local machine.
# .env.dev.local is ignored by git. Do not commit real passwords or API keys.

# Default development setup: local PostgreSQL + local Redis.
DEV_DB_HOST=localhost
DEV_DB_PORT=5432
DEV_DB_NAME=aiwriting
DEV_DB_USER=aiwriting
DEV_DB_PASSWORD=change-me

DEV_REDIS_URL=redis://localhost:6379/0

# Must be stable for a given database because it encrypts stored provider API keys.
# Use a random value with at least 32 characters in real development.
AIWRITING_SECRET_KEY=change-me-at-least-32-chars

# Optional SSH tunnel settings. Leave empty unless you explicitly use scripts/start-vps-postgres-tunnel.ps1.
DEV_TUNNEL_HOST=
DEV_TUNNEL_USER=
DEV_TUNNEL_IDENTITY_FILE=
DEV_TUNNEL_POSTGRES_LOCAL_PORT=5432
DEV_TUNNEL_POSTGRES_REMOTE_PORT=5432
DEV_TUNNEL_REDIS_LOCAL_PORT=6379
DEV_TUNNEL_REDIS_REMOTE_PORT=6379
